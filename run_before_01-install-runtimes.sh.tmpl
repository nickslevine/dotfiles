#!/bin/bash
set -euo pipefail

{{ if eq .chezmoi.os "linux" }}
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
{{ else }}
eval "$(brew shellenv 2>/dev/null || true)"
{{ end }}

# Install mise
if ! command -v mise &>/dev/null; then
  echo ">>> Installing mise..."
  curl -fsSL https://mise.run | sh
fi
export PATH="$HOME/.local/bin:$PATH"

# Install runtimes (use -g writes config, install -y forces download)
echo ">>> Installing runtimes via mise..."
mise use -g node@lts
mise use -g bun@latest
mise use -g rust@latest
mise use -g uv@latest
mise use -g fzf@latest
mise install -y
mise reshim

# Use shims
export PATH="$HOME/.local/share/mise/shims:$PATH"

# Debug - verify tools exist
echo ">>> Checking: uv=$(which uv 2>/dev/null || echo MISSING) node=$(which node 2>/dev/null || echo MISSING)"

# uv tools
echo ">>> Installing uv tools..."
"$HOME/.local/share/mise/shims/uv" tool install pyright
"$HOME/.local/share/mise/shims/uv" tool install nvitop

# AI CLI tools
echo ">>> Installing AI CLI tools..."
curl -fsSL https://claude.ai/install.sh | bash
"$HOME/.local/share/mise/shims/npm" install -g @openai/codex
"$HOME/.local/share/mise/shims/npm" install -g opencode-ai
