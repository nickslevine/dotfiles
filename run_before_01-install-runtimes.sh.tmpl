#!/bin/bash
set -euo pipefail

{{ if eq .chezmoi.os "linux" }}
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
{{ else }}
eval "$(brew shellenv 2>/dev/null || true)"
{{ end }}

# Install mise
if ! command -v mise &>/dev/null; then
  echo ">>> Installing mise..."
  curl -fsSL https://mise.run | sh
fi
export PATH="$HOME/.local/bin:$PATH"

# Install runtimes explicitly
echo ">>> Installing runtimes via mise..."
mise use -g node@lts -y
mise use -g bun@latest -y
mise use -g rust@latest -y
mise use -g uv@latest -y
mise use -g fzf@latest -y
mise reshim

# Verify shims are available
export PATH="$HOME/.local/share/mise/shims:$PATH"
echo ">>> uv path: $(which uv || echo 'NOT FOUND')"

# uv tools
echo ">>> Installing uv tools..."
uv tool install pyright
uv tool install nvitop

# AI CLI tools
echo ">>> Installing AI CLI tools..."
curl -fsSL https://claude.ai/install.sh | bash
npm install -g @openai/codex
npm install -g opencode-ai
