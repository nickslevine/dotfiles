#!/bin/bash
set -euo pipefail

{{ if eq .chezmoi.os "linux" }}
# Install fish shell via apt
if ! command -v fish &>/dev/null; then
  echo ">>> Installing fish..."
  if [ "$(id -u)" -eq 0 ]; then
    apt-get update -qq && apt-get install -y -qq fish
  else
    sudo apt-get update -qq && sudo apt-get install -y -qq fish
  fi
fi

# Install Homebrew for Linux
if ! command -v brew &>/dev/null; then
  echo ">>> Installing Homebrew..."
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
{{ else }}
eval "$(brew shellenv 2>/dev/null || true)"
{{ end }}

# Install brew packages (skip already installed)
if command -v brew &>/dev/null; then
  echo ">>> Checking brew packages..."
  PACKAGES="helix tmux ripgrep zellij eza bat fd lazygit gh"
  {{ if eq .chezmoi.os "linux" }}
  PACKAGES="$PACKAGES google-cloud-sdk"
  {{ end }}
  for pkg in $PACKAGES; do
    brew list "$pkg" &>/dev/null || brew install "$pkg"
  done
fi
